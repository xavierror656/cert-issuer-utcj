APP_NAME="UTCJ Microcredentials API"
APP_ENV=development
HOST=0.0.0.0
PORT=8000
PUBLIC_BASE_URL=http://localhost:8000

# dev: mockchain | public demo: ethereum_sepolia
DEFAULT_CHAIN=mockchain

ISSUER_NAME="Universidad Tecnologica de Ciudad Juarez"
ISSUER_SLUG=utcj
ISSUER_EMAIL=microcredenciales@utcj.edu.mx
ISSUER_WEBSITE=https://www.utcj.edu.mx
ISSUER_INTRO_URL=https://www.utcj.edu.mx/nosotros/
ISSUER_DESCRIPTION="Plataforma institucional de microcredenciales verificables de la Universidad Tecnologica de Ciudad Juarez."
ISSUER_LOGO_PATH=assets/logos/utcj-logo.png

# For mockchain you can leave these empty. For Sepolia, provide the private key file and public base URL over HTTPS.
ISSUER_PRIVATE_KEY_FILE=
ISSUER_PRIVATE_KEY_FORMAT=ethereum_hex
ISSUING_ADDRESS=
VERIFICATION_METHOD=
ISSUER_ASSERTION_JWK_JSON=

SAFE_MODE=false
MAX_RETRY=3

ETHERSCAN_API_TOKEN=
ETHEREUM_RPC_URL=
SEPOLIA_RPC_URL=
GOERLI_RPC_URL=
BLOCKCYPHER_API_TOKEN=
BITCOIND=false

NONCE=0
GAS_PRICE=25000000000
GAS_LIMIT=25000
MAX_PRIORITY_FEE_PER_GAS=0
GAS_PRICE_DYNAMIC=false

TX_FEE=0.0006
DUST_THRESHOLD=0.0000275
SATOSHI_PER_BYTE=250
BATCH_SIZE=1

DATA_DIR=data/utcj_microcredentials
